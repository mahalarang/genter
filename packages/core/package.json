{
  "name": "genter",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "bin": {
    "genter": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^26.1.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "ffmpeg-static": "^5.3.0",
    "ora": "^9.4.1",
    "ytdlp-nodejs": "^3.4.4"
  }
}
